<UserControl x:Class="sentry.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:sentry"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1920">


    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="NavyBlue" Color="#2E3A59"/>
        <SolidColorBrush x:Key="LightBlue" Color="#C5D1F0"/>
        <SolidColorBrush x:Key="LighterBlue" Color="#E8EDF9"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4A5A8A"/>
        <SolidColorBrush x:Key="Green" Color="#4CAF50"/>

        <!-- Styles -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#4A5A8A"/>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LightBlue}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="InnerCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <!-- Increased font size -->
            <Setter Property="FontSize" Value="16"/>
            <!-- Increased padding -->
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="8" BorderBrush="#B0C0E0" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="BorderBrush" Value="#B0C0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F7FA"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#2E3A59"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#D0D0D0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                    CornerRadius="10"
                    Padding="15,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#6A78A1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <StackPanel Grid.Column="0">
                <!-- Event Management -->
                <Border Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="Event Management" FontSize="18" 
                              FontWeight="Bold" Foreground="#2E3A59"/>
                            <Button x:Name="btnAddEvent" 
                                    Content="+ Add Event" 
                                    HorizontalAlignment="Right" 
                                    VerticalAlignment="Top"
                                    Margin="0"
                                    Padding="15,10"
                                    Background="#4A90D9"
                                    Foreground="White"
                                    FontSize="13"
                                    Click="btnAddEvent_Click"
                                    Style="{StaticResource ActionButton}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="10"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Border Style="{StaticResource InnerCard}">
                            <StackPanel>
                                <TextBlock Text="Current Event:" FontWeight="SemiBold" 
                                  Foreground="#2E3A59" FontSize="16"/>
                                <TextBlock Text="USLT 61st Founding Anniversary" 
                                  TextWrapping="Wrap" Margin="0,5,0,0"
                                  Foreground="#2E3A59" FontSize="15" x:Name="tbEventName"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InnerCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="📅" Margin="0,0,5,0" FontSize="15"/>
                                    <TextBlock Text="February 11, 2026" Foreground="#2E3A59" FontSize="15" x:Name="tbEventDate"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="🕐" Margin="0,0,5,0" FontSize="15"/>
                                    <TextBlock Text="7:30 am - 11:00 pm" Foreground="#2E3A59" FontSize="15" x:Name="tbEventTime"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="📍" Margin="0,0,5,0" FontSize="15"/>
                                    <TextBlock Text="University of Saint Louis Tugue..." 
                                      Foreground="#2E3A59" TextTrimming="CharacterEllipsis" FontSize="15" x:Name="tbEventLocation"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Process of Attendance -->
                <Border Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <TextBlock Text="PROCESS OF ATTENDANCE" FontSize="18" 
                          FontWeight="Bold" Foreground="#2E3A59" 
                          HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <Border Background="{StaticResource LighterBlue}" 
                       CornerRadius="10" Padding="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <RadioButton Content="Time-in"
                              IsChecked="True"
                              FontWeight="DemiBold"
                              x:Name="time_in"
                              GroupName="AttendanceType"
                              Style="{StaticResource RadioButtonStyle}"
                              Width="110"
                              FontSize="16"/>

                                <RadioButton Content="Time-out"
                              IsChecked="False"
                              FontWeight="DemiBold"
                              x:Name="time_out"
                              GroupName="AttendanceType"
                              Style="{StaticResource RadioButtonStyle}"
                              Width="110"
                              FontSize="16"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="TIMEZONE" FontSize="18" FontWeight="Bold" 
                          Foreground="#2E3A59" HorizontalAlignment="Center" 
                          Margin="0,15,0,10"/>

                        <Border Background="{StaticResource LighterBlue}" 
                       CornerRadius="10" Padding="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                                <RadioButton Content="AM"
                              IsChecked="True"
                              FontWeight="DemiBold"
                              Width="110"
                              GroupName="AMPM"
                              Style="{StaticResource RadioButtonStyle}"
                              FontSize="16"/>

                                <RadioButton Content="PM"
                              FontWeight="DemiBold"
                              Width="110"
                              GroupName="AMPM"
                              Style="{StaticResource RadioButtonStyle}"
                              FontSize="16"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Center Panel - Attendance Tracker -->
            <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ATTENDANCE TRACKER" FontSize="20" FontWeight="Black" 
                      Foreground="#2E3A59" HorizontalAlignment="Center"/>

                    <!-- Stats -->
                    <Border Grid.Row="1" Background="{StaticResource LighterBlue}" 
                   CornerRadius="15" Padding="20" Margin="0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="Total Time - In:" FontSize="16" 
                                  Foreground="#2E3A59"/>
                                <TextBlock Text="100" FontSize="36" FontWeight="Bold" 
                                  Foreground="#2E3A59" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Total Time - Out:" FontSize="16" 
                                  Foreground="#2E3A59"/>
                                <TextBlock Text="100" FontSize="36" FontWeight="Bold" 
                                  Foreground="#2E3A59" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- User Info -->
                    <Border Grid.Row="2" Background="{StaticResource LighterBlue}" 
                   CornerRadius="10" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="50" Height="50" Fill="#D0D0D0" Margin="0,0,15,0"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="NAME:" FontSize="15" Foreground="#666"/>
                                <TextBlock Text="ID #:" FontSize="15" Foreground="#666" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="COURSE:" FontSize="15" Foreground="#666"/>
                                <TextBlock Text="YEAR LEVEL:" FontSize="15" Foreground="#666" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Recent Activity Table -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="RECENT ACTIVITY:" FontSize="18" FontWeight="Bold" 
                          Foreground="#2E3A59" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                       BorderBrush="#D0D0D0" BorderThickness="1">
                            <DataGrid x:Name="AttendanceGrid" Style="{StaticResource DataGridStyle}" FontSize="20" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID #" Width="90" Binding="{Binding ID_number}"/>
                                    <DataGridTextColumn Header="Full Name" Width="*" Binding="{Binding Name}"/>
                                    <DataGridTextColumn Header="Year Level" Width="60" Binding="{Binding Year_Level}"/>
                                    <DataGridTextColumn Header="Time in (AM)" Width="90" Binding="{Binding time_in_am}"/>
                                    <DataGridTextColumn Header="Time out (AM)" Width="90" Binding="{Binding time_out_am}"/>
                                    <DataGridTextColumn Header="Time in (PM)" Width="90" Binding="{Binding time_in_pm}"/>
                                    <DataGridTextColumn Header="Time out (PM)" Width="90" Binding="{Binding time_out_pm}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Bottom Buttons -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" 
                       HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Style="{StaticResource GreenButton}" Margin="0,0,10,0" x:Name="btnExcel">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" 📊" Margin="0,0,0,0" FontSize="20"/>
                                <TextBlock Text="EXPORT TO EXCEL " FontSize="20"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ActionButton}" x:Name="btnSave">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" 💾" Margin="0,0,0,0" FontSize="20"/>
                                <TextBlock Text="SAVE " FontSize="20" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Panel -->
            <StackPanel Grid.Column="2">
                <!-- Manual Input -->
                <Border Style="{StaticResource PanelCard}">
                    <StackPanel>
                        <TextBlock Text="MANUAL INPUT" FontSize="16" FontWeight="SemiBold" 
                          Foreground="#2E3A59" HorizontalAlignment="Center"/>

                        <Border Background="{StaticResource LighterBlue}" CornerRadius="10" 
                       Padding="20" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="ID #:" FontSize="15" Foreground="#2E3A59" 
                                  Margin="0,0,0,5" />
                                <TextBox Style="{StaticResource TextBoxStyle}"/>

                                <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Center" Margin="0,15,0,0">
                                    <Button Content="Confirm" Style="{StaticResource ActionButton}" 
                                                    Width="80" Margin="0,0,10,0" 
                                                    x:Name="btnConfirmAttendance"
                                                    Click="btnConfirmAttendance_Click"/>
                                    
                                    <Button Content="Cancel" Style="{StaticResource ActionButton}" 
                                   Width="80"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RFID Status -->
                <Border Background="{StaticResource LightBlue}" CornerRadius="10" 
               Padding="15" Margin="10,5,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="📡" FontSize="17" Margin="0,0,8,0"/>
                        <TextBlock Text="RFID Scanner Status:" FontWeight="Bold" 
                          Foreground="#2E3A59" FontSize="17"/>
                        <TextBlock Text=" CONNECTED" FontWeight="Bold" 
                          Foreground="{StaticResource Green}" Margin="5,0,0,0" FontSize="17"/>
                        <TextBlock Text=" ✓" Foreground="{StaticResource Green}" 
                          FontWeight="Bold" FontSize="17"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        <!-- Popup Container (initially hidden) -->
        <Grid x:Name="PopupContainer" 
              Visibility="Collapsed" 
              Panel.ZIndex="100">
            <!-- Popup will be injected here -->
        </Grid>
        
    </Grid>
</UserControl>
