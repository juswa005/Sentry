<UserControl x:Class="sentry.Admin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:sentry"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1920">
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="NavyBlue" Color="#2E3A59"/>
        <SolidColorBrush x:Key="LightBlue" Color="#C5D1F0"/>
        <SolidColorBrush x:Key="LighterBlue" Color="#E8EDF9"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4A5A8A"/>
        <SolidColorBrush x:Key="Green" Color="#4CAF50"/>

        <!-- Styles -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A5A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#4A5A8A"/>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LightBlue}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

        <Style x:Key="InnerCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="8" BorderBrush="#B0C0E0" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource LighterBlue}"/>
            <Setter Property="BorderBrush" Value="#B0C0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F5F7FA"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#2E3A59"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#D0D0D0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                    CornerRadius="10"
                    Padding="15,5">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#6A78A1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#4A90D9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#E8F0FE"/>
            <Setter Property="Foreground" Value="#2E3A59"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="TextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="730"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Students List -->
            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="10,10,10,10" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="Students List" 
                               FontSize="20" 
                               FontWeight="Black" 
                               Foreground="#2E3A59" 
                               HorizontalAlignment="Left"
                               Margin="0,0,0,15"/>

                    <!-- DataGrid - Takes all available space -->
                    <Border Grid.Row="1" 
                            Background="#F5F5FA" 
                            CornerRadius="15" 
                            BorderBrush="#C5C5E0" 
                            BorderThickness="1">

                        <Border Grid.Row="1" Background="White" CornerRadius="10">
                            <DataGrid x:Name="MasterListGrid" Style="{StaticResource DataGridStyle}" FontSize="20">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID #" Width="60" Binding="{Binding ID_number}"/>
                                    <DataGridTextColumn Header="Full Name" Width="*" Binding="{Binding Name}"/>
                                    <DataGridTextColumn Header="Year Level" Width="90" Binding="{Binding Year_Level}"/>
                                    <DataGridTextColumn Header="Program" Width="90" Binding="{Binding Program}"/>
                                    <DataGridTextColumn Header="RFID" Width="90" Binding="{Binding RFID_ID}"/>
                                    <DataGridTextColumn Header="Department" Width="90" Binding="{Binding Department}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Border>

                    <!-- Bottom Buttons -->
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,15,0,0">
                        <Button Style="{StaticResource GreenButton}" Margin="0,0,10,0" x:Name="btnExcel">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" 💾" Margin="0,0,0,0" FontSize="20"/>
                                <TextBlock Text="EXPORT STUDENTS " FontSize="20"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right Side - Registration Panel + Image -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Registration Panel -->
                <Border Grid.Row="0" Margin="10" Style="{StaticResource PanelCard}"
                        Background="#FFC5D1F0" 
                        CornerRadius="15" 
                        BorderBrush="#C5C5E0" 
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" 
                                          BlurRadius="10" 
                                          Color="#A0A0C0" 
                                          Opacity="0.3"/>
                    </Border.Effect>

                    <Grid Margin="15,10,15,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Side - Image Section -->
                        <StackPanel Grid.Column="0" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Top"
                                    Margin="0,10,0,0">

                            <!-- Profile Image Placeholder -->
                            <Border Width="120" 
                                    Height="120" 
                                    Background="#E0E8F5" 
                                    CornerRadius="60"
                                    BorderBrush="#C5D5E8" 
                                    BorderThickness="2">
                                <Grid>
                                    <Ellipse Width="100" Height="100">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="/Images/bitsync.jpg" Stretch="UniformToFill"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Grid>
                            </Border>

                            <!-- Import Image Button -->
                            <Button Content="📥 Import Image" 
                                    Margin="0,15,0,0"
                                    Padding="15,8"
                                    Background="#B8B8C8"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="12"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="20"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" 
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Right Side - Form Fields -->
                        <Grid Grid.Column="1" Margin="20,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Name -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                                <TextBlock Text="Name:" 
                                           Foreground="#4A4A6A" 
                                           FontSize="14"
                                           Margin="0,0,0,5"/>
                                <Border Background="#E0E0E5" 
                                        CornerRadius="8" 
                                        Padding="10,6">
                                    <TextBox Background="Transparent" 
                                             BorderThickness="0"
                                             FontSize="14"
                                             Foreground="#333333"/>
                                </Border>
                            </StackPanel>

                            <!-- ID # -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                                <TextBlock Text="ID #:" 
                                           Foreground="#4A4A6A" 
                                           FontSize="14"
                                           Margin="0,0,0,5"/>
                                <Border Background="#E0E0E5" 
                                        CornerRadius="8" 
                                        Padding="10,6"
                                        Width="200"
                                        HorizontalAlignment="Left">
                                    <TextBox Background="Transparent" 
                                             BorderThickness="0"
                                             FontSize="14"
                                             Foreground="#333333"/>
                                </Border>
                            </StackPanel>

                            <!-- RFID # and Department -->
                            <Grid Grid.Row="2" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="RFID #:" 
                                               Foreground="#4A4A6A" 
                                               FontSize="14"
                                               Margin="0,0,0,5"/>
                                    <Border Background="#E0E0E5" 
                                            CornerRadius="8" 
                                            Padding="10,6">
                                        <TextBox Background="Transparent" 
                                                 BorderThickness="0"
                                                 FontSize="14"
                                                 Foreground="#333333"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Department" 
                                               Foreground="#4A4A6A" 
                                               FontSize="14"
                                               Margin="0,0,0,5"/>
                                    <Border Background="#D0D0D8" 
                                            CornerRadius="8" 
                                            Padding="10,6">
                                        <ComboBox Background="Transparent" 
                                                  BorderThickness="0"
                                                  FontSize="14"
                                                  Foreground="#666666"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Program and Year Level -->
                            <Grid Grid.Row="3" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Program:" 
                                               Foreground="#4A4A6A" 
                                               FontSize="14"
                                               Margin="0,0,0,5"/>
                                    <Border Background="#D0D0D8" 
                                            CornerRadius="8" 
                                            Padding="10,6">
                                        <ComboBox Background="Transparent" 
                                                  BorderThickness="0"
                                                  FontSize="14"
                                                  Foreground="#666666"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Year Level:" 
                                               Foreground="#4A4A6A" 
                                               FontSize="14"
                                               Margin="0,0,0,5"/>
                                    <Border Background="#D0D0D8" 
                                            CornerRadius="8" 
                                            Padding="10,6">
                                        <ComboBox Background="Transparent" 
                                                  BorderThickness="0"
                                                  FontSize="14"
                                                  Foreground="#666666"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Action Buttons -->
                            <StackPanel Grid.Row="4" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0">

                                <Button Content="✕ Cancel" 
                                        Margin="0,0,15,0"
                                        Padding="20,10"
                                        Background="#B8B8C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="✓ Add" 
                                        Margin="0,0,15,0"
                                        Padding="25,10"
                                        Background="#B8B8C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="✓ Update" 
                                        Margin="0,0,15,0"
                                        Padding="25,10"
                                        Background="#B8B8C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Content="⊗ Clear" 
                                        Padding="20,10"
                                        Background="#B8B8C0"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="12"
                                        Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="20"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Bottom Image with Rounded Corners -->
                <Border Grid.Row="1" 
                        Margin="10,0,10,10"
                        CornerRadius="15"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid Width="590" Height="350">
                       
                        <Image Source="/Images/about.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
            </Grid>
        </Grid>
    </Grid>
</UserControl>